# Haines index
feld=ham; ptyp=hc; cmth=fill; cint=1; >
  xwin=XWIN; ywin=YWIN; >
  smth=1; hvbr=HVBR; cbeg=3; cend=6;>
  nmin; nmsg; titl=Haines_Index_(850-700mb);>
  cosq=            3,c38,>
         3,c34,    4,c34,>
         4,c30,    5,c30,>
         5,c66,    6,c66,>
         6,c62
feld=map; ptyp=hb; outy=Earth..2L4; ouds=solid; oulw=2; cint=360; colr=def.foreground
feld=box; ptyp=hb; crsa=CRSA; crsb=CRSB
===========================================================================
# Haines index
